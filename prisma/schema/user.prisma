model User {
    id         String      @id @default(uuid())
    name       String
    email      String      @unique
    password   String
    role       Role        @default(USER)
    borrowings Borrowing[] @relation("UserBorrowings")

    // INFO 
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")
}

enum Role {
    USER
    ADMIN
}
