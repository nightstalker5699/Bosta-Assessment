model Borrowing {
    id String @id @default(uuid())

    // user entity
    userId String @map("user_id")
    user   User   @relation("UserBorrowings", fields: [userId], references: [id])

    // book entity
    bookId String @map("book_id")
    book   Book   @relation("BookBorrowed", fields: [bookId], references: [id])

    status     Status    @default(BORROWED)
    borrowDate DateTime  @default(now()) @map("borrow_date") @db.Timestamptz()
    dueDate    DateTime  @map("due_date") @db.Timestamptz()
    returnDate DateTime? @map("return_date") @db.Timestamptz()

    // INFO
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
    updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

    @@index([userId])                  // list borrowings by user
    @@index([bookId])                  // list borrowings by book
    @@index([status])                  // filter by status
    @@index([dueDate])                 // overdue queries
    @@index([status, dueDate])         // overdue = BORROWED + dueDate < now
    @@index([createdAt])               // reports date range filter
}

enum Status {
    BORROWED
    RETURNED
}
